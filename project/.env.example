# Supabase Configuration (required for production database mode)
# Leave as placeholder to use the built-in mock/demo mode
VITE_SUPABASE_URL=https://placeholder.supabase.co
VITE_SUPABASE_ANON_KEY=placeholder-anon-key

# Optional: Override app title
# VITE_APP_TITLE=EcoWarrior

# Optional: Set to 'true' to force mock mode even if Supabase creds are provided
# VITE_MOCK_MODE=true
